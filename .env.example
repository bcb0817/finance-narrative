# X API
API_KEY=
API_KEY_SECRET=
ACCESS_TOKEN=
ACCESS_TOKEN_SECRET=
# レポート機能（インプレ取得）で使う場合あり。Developer Portal の Keys and tokens から取得
BEARER_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_GENERATE_MODEL=gpt-5-mini
OPENAI_REVIEW_MODEL=gpt-5-nano
OPENAI_MONTHLY_BUDGET_USD=5.0

# Finnhub
FINNHUB_API_KEY=
FINNHUB_ECON=0

# Public identity / HTTP identification (replace only in your local .env)
DIAGRAM_HANDLE=@finance_example
RSS_USER_AGENT=example-finance-bot/1.0
SEC_USER_AGENT=example-finance-bot bot-contact@example.com

# Runtime
TZ=Asia/Tokyo
# POST_ENABLED=false のときは実投稿しない（dry-run: 判定・画像生成まで実行）。
# 本番投稿する場合のみ true にする:
# POST_ENABLED=true
POST_ENABLED=false

# Paths
STATE_DIR=data
OUTPUT_DIR=outputs
LOG_DIR=logs

# News Bot
NEWS_DEFAULT_MODE=image
NEWS_RUN_EVERY_MINUTES=30
NEWS_MAX_POSTS_PER_RUN=1

# Global volume and cost guardrails (all X writes, including replies)
DAILY_POST_LIMIT=30
HOURLY_POST_LIMIT=2
TICKER_COOLDOWN_MINUTES=180
THEME_COOLDOWN_MINUTES=90
THREADS_ENABLED=false
X_CONTENT_CREATE_USD=0.015
X_WRITE_MONTHLY_BUDGET_USD=15.0
# --- News Bot 投稿ゲート（通過率チューニング。数字を下げると通りやすい）---
NEWS_POST_VALUE_THRESHOLD=7
NEWS_RELEVANCE_THRESHOLD=8
NEWS_BUZZ_THRESHOLD=8
NEWS_NARRATIVE_THRESHOLD=8
NEWS_THEME_THRESHOLD=8
# 評価済みニュースの再評価を抑制する時間（時間）
EVALUATED_TTL_HOURS=6

# Narrative Bot
NARRATIVE_POST_VALUE_THRESHOLD=8

# Market Map 投稿ゲート（大きな市場変化があるときだけ投稿）
MARKET_MAP_MIN_ABS_CHANGE_USD=300000000000
MARKET_MAP_MIN_INDEX_PCT=0.5
MARKET_MAP_SECTOR_SKEW=0.6

# Scheduler
RUN_WINDOW_MINUTES=10
CATCH_UP_ENABLED=false
LOCK_FILE=data/finance_bot.lock

# Fonts（任意: 日本語フォントを明示指定する場合）
# FONT_PATH=C:/Windows/Fonts/YuGothM.ttc


# Daily performance learning
# 毎日report実行時、直近24時間のインプレ上位3件をAIレビューし、
# knowledge/viral_patterns/latest_patterns.md を翌日以降の生成に反映
PERFORMANCE_LEARNING_ENABLED=true
PERFORMANCE_LEARNING_TOP_N=3
PERFORMANCE_LEARNING_LOOKBACK_HOURS=24
PERFORMANCE_LEARNING_MAX_CONTEXT_CHARS=3500
